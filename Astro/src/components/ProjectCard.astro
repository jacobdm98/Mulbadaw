---
// src/components/ProjectCard.astro
interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  lang: 'en' | 'sw'; // Add this prop
}

const { title, description, image, link, lang } = Astro.props;

// Simple dictionary for button text
const labels = {
  en: "View Project →",
  sw: "Tazama Mradi →"
};
---

<div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow">
  <img src={image} alt={title} class="w-full h-48 object-cover" />
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-gray-600 mb-4">{description}</p>
    <a href={link} class="text-yellow-700 font-semibold hover:underline">
      {labels[lang]}
    </a>
  </div>
</div>