---
// src/layouts/ProjectLayout.astro
import Layout from './Layout.astro';

interface Props {
  title: string;
  image: string;
  lang: 'en' | 'sw';
}

const { title, image, lang } = Astro.props;
---

<Layout title={title} lang={lang}>
  <article class="max-w-4xl mx-auto px-4 py-8">
    <!-- Hero Image for the project -->
    <img src={image} alt={title} class="w-full h-80 object-cover rounded-2xl shadow-lg mb-8" />
    
    <!-- Title -->
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{title}</h1>
    
    <!-- The Content Slot -->
    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
      <slot />
    </div>

    <!-- Back Button -->
    <div class="mt-12">
      <a href={`/${lang}/projects`} class="text-yellow-700 font-medium hover:underline">
        {lang === 'en' ? '← Back to Projects' : '← Rudi kwenye Miradi'}
      </a>
    </div>
  </article>
</Layout>